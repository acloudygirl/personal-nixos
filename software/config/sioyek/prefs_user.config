# 打开时适应页面宽度
fit_to_page_width 1

# 平滑滚动
smooth_scroll_speed 0.5

# 鼠标滚轮速度
wheel_zoom_on_cursor 1

# 记住阅读位置
should_launch_new_window 0

# 自动恢复上次阅读位置
restore_session_data 1

# 搜索时高亮所有结果
highlight_search_results 1

# 显示状态栏
status_bar 1

# 显示页码
page_number 1

# 保存阅读历史
create_table_of_contents_if_not_exists 1

# 提前缓存页面
preload_next_page 1

# 深色模式
startup_commands toggle_dark_mode
dark_mode_background_color 0.0 0.0 0.0
